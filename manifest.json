{
  "manifest_version": 3,
  "name": "BahisKalkanı - Chrome Eklentisi",
  "version": "1.0",
  "description": "Bahis içeriğini tespit edip kapatan koruma eklentisi",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["detector.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["keywords.json", "mesru_alanlar.json"],
      "matches": ["<all_urls>"]
    }
  ]
}